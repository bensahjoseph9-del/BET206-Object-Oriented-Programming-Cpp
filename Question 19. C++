#include <iostream>
using namespace std;

int main()
{
    float reading, sum=0, average;
    int count=0;

    for(int i=1; i<=12; i++)
    {
        cout<<"Enter sensor reading: ";
        cin>>reading;

        if(reading == 999)
            continue;

        sum += reading;
        count++;
    }

    average = sum/count;

    cout<<"Average Valid Reading = "<<average;

    return 0;
}
