#include <iostream>
using namespace std;

int main()
{
    float power, total = 0;

    for(int i=1; i<=20; i++)
    {
        cout << "Enter appliance power rating (W): ";
        cin >> power;

        total += power;

        if(total > 5000)
        {
            cout << "Maximum load exceeded. Stop adding appliances.\n";
            break;
        }
    }

    cout << "Final Total Load = " << total << " W";

    return 0;
}
